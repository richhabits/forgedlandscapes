# ══ FORGED LANDSCAPES — environment ══
# Everything is optional: the site runs in full preview/demo mode with zero
# keys. Add each block to unlock the real behaviour. All free tiers.

# ── Supabase (database, auth, storage) ──
# Attach via Vercel → project → Storage → Create Database → Supabase (free),
# which injects these automatically — or paste from supabase.com dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never expose client-side). Injected by the Vercel integration;
# unlocks admin-side lead status updates. App works without it (RLS handles inserts).
SUPABASE_SERVICE_ROLE_KEY=

# ── AI assessor (Groq — free tier, console.groq.com) ──
# Without a key the assessor runs its scripted mode: same questions,
# same lead capture, zero AI dependency.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email (Resend — free tier, resend.com) ──
# Without a key, leads still land in the database; only email alerts skip.
# Until you verify a domain, Resend free only delivers to YOUR own inbox —
# perfect for admin alerts, sort the domain later for client emails.
RESEND_API_KEY=
ADMIN_EMAIL=richhabitslondon@gmail.com
EMAIL_FROM="Forged Landscapes <onboarding@resend.dev>"

# ── Rate limiting (Upstash Redis — free tier, upstash.com) ──
# Optional. Without these, an in-memory per-instance limiter is used (fine
# for low traffic). Set both to share limits across serverless instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
